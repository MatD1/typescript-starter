# Application
PORT=3000
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug
# Detailed admin request telemetry is retained for this many days.
REQUEST_LOG_RETENTION_DAYS=30
# Requests slower than this threshold are emitted as Railway warnings.
SLOW_REQUEST_MS=2000

# better-auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# CORS — comma-separated origins allowed to call auth endpoints
# Leave empty or omit to allow all origins (development default)
ALLOWED_ORIGINS=https://myapp.example.com,https://staging.myapp.example.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/nsw_transport

# Valkey / Redis
REDIS_URL=redis://localhost:6379

# NSW Transport Open Data API
# Paste the raw key value. Do not include quotes or the "apikey " scheme.
# The TfNSW application must be subscribed to every API product used,
# including realtime alerts, realtime feeds, and Trip Planner APIs.
NSW_TRANSPORT_API_KEY=your-nsw-transport-api-key-here
# Dedicated key for GTFS schedule ingest (recommended in production).
# Create a second Open Data Hub application with GTFS schedule products enabled.
# Falls back to NSW_TRANSPORT_API_KEY when unset.
NSW_TRANSPORT_STATIC_API_KEY=
NSW_TRANSPORT_BASE_URL=https://api.transport.nsw.gov.au

# Railway / S3-compatible object storage for GTFS ZIP persistence
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=your-gtfs-bucket
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Audit trail
# Use distinct least-privilege credentials and an Object-Lock-enabled,
# versioned bucket. Set AUDIT_ARCHIVE_DISABLED=true only for local development.
AUDIT_ARCHIVE_DISABLED=true
AUDIT_IP_HASH_SECRET=replace-with-a-dedicated-random-secret
AUDIT_SIGNING_SECRET=replace-with-a-different-random-secret
AUDIT_S3_ENDPOINT=https://s3.example.com
AUDIT_S3_REGION=auto
AUDIT_S3_BUCKET=jrail-audit
AUDIT_S3_ACCESS_KEY_ID=
AUDIT_S3_SECRET_ACCESS_KEY=
# Set when running behind Railway or another trusted reverse proxy.
TRUST_PROXY=true

# Supabase (for SSO exchange)
# JWT secret from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
